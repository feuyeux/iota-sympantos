digraph IotaLayeredModuleMap {
  graph [rankdir=TB, bgcolor="white", fontname="Arial", labelloc="t", label="iota-sympantos layered module relationship map (dashed = IPC/process/network boundary)", nodesep=0.45, ranksep=0.75];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#475569", fontname="Arial", fontsize=11];
  edge [color="#334155", fontname="Arial", fontsize=10, arrowsize=0.7];

  subgraph cluster_entry {
    label="Entry Layer"; color="#cbd5e1"; style="rounded,filled"; fillcolor="#f8fafc";
    main [label="main.rs\nTokio entrypoint"];
  }

  subgraph cluster_presentation {
    label="Presentation Layer"; color="#bae6fd"; style="rounded,filled"; fillcolor="#f0f9ff";
    cli [label="cli.rs\ncommands/output"];
    tui [label="tui.rs\nterminal runtime loop"];
    composer [label="tui/composer.rs\ninput editor"];
    markdown [label="tui/markdown.rs\nmarkdown render"];
    status [label="tui/status_bar.rs\nstatus bar"];
    theme [label="tui/theme.rs\nstyles"];
    state [label="tui/state.rs\nhistory state"];
  }

  subgraph cluster_service {
    label="Service Orchestration Layer"; color="#d9f99d"; style="rounded,filled"; fillcolor="#f7fee7";
    engine [label="engine.rs\nIotaEngine orchestration"];
    agent [label="agent.rs\ndaemon TCP plane"];
  }

  subgraph cluster_protocol {
    label="Protocol Adapter Layer"; color="#fed7aa"; style="rounded,filled"; fillcolor="#fff7ed";
    acp [label="acp.rs\nAcpClient JSON-RPC"];
    acp_wire [label="acp_wire.rs\nline read/parse"];
    acp_session [label="acp_session.rs\nper-backend mcpServers shape\nGemini/ClaudeCode/Hermes/Codex"];
    acp_permission [label="acp_permission.rs\nauto-approve iota_* (optionId)\nTUI channel / stdin fallback"];
    runtime_event [label="runtime_event.rs\nevent mapping"];
    mcp_router [label="mcp_router.rs\nACP tool intercept"];
    mcp_client [label="mcp_client.rs\nstdio MCP client"];
  }

  subgraph cluster_context {
    label="Context Fabric Layer"; color="#f5d0fe"; style="rounded,filled"; fillcolor="#fdf4ff";
    context [label="context.rs\ncontext capsule\n+ &lt;memory-tools&gt; injection"];
    skills [label="skills.rs\nSkillRegistry"];
    skill_runner [label="skill_runner.rs\nengine-run MCP skills"];
    context_mcp [label="context_mcp.rs\niota-context MCP"];
    fun_mcp [label="fun_mcp.rs\niota-fun MCP"];
    native_materializer [label="native_materializer.rs\nnative projection"];
    skill_registry_cache [label="skill_registry_cache.rs\nskill pull/cache"];
  }

  subgraph cluster_store {
    label="Store Layer"; color="#cbd5e1"; style="rounded,filled"; fillcolor="#f1f5f9";
    event_store [label="event_store.rs\nexecutions/events"];
    memory [label="memory.rs\nmemory SQLite/FTS"];
    approval [label="approval.rs\napproval policy/store"];
    session_ledger [label="session_ledger.rs\nsessions/handoff"];
  }

  subgraph cluster_external {
    label="External Process / Network Boundaries"; color="#fecaca"; style="rounded,filled"; fillcolor="#fef2f2";
    daemon_proc [label="iota __daemon\nchild process", color="#d97706", fillcolor="#fffbeb"];
    tcp [label="127.0.0.1:47661\nTCP JSON line", color="#d97706", fillcolor="#fffbeb"];
    acp_backend [label="ACP backend process\nClaude/Codex/Gemini/Hermes/OpenCode", color="#dc2626", fillcolor="#fff1f2"];
    mcp_sidecar [label="MCP sidecar process\niota context-mcp/fun-mcp", color="#dc2626", fillcolor="#fff1f2"];
    tool_proc [label="compiler/interpreter process\npython/node/rustc/go/java/c++/zig", color="#dc2626", fillcolor="#fff1f2"];
    git [label="git status --short\nchild process", color="#dc2626", fillcolor="#fff1f2"];
    network [label="HTTP(S) skill source\nnetwork/local source", color="#2563eb", fillcolor="#eff6ff"];
  }

  subgraph cluster_config {
    label="Configuration and Shared Utility Layer"; color="#bbf7d0"; style="rounded,filled"; fillcolor="#ecfdf5";
    config [label="config.rs\nnimia/env/MCP config"];
    utils [label="utils.rs\ntime/summary/lock"];
  }

  main -> cli [label="cli::run"];
  cli -> tui [label="iota / tui"];
  cli -> engine [label="run / bench direct"];
  cli -> agent [label="--daemon client"];
  cli -> event_store [label="observability"];
  cli -> native_materializer [label="native-materialize"];
  cli -> skill_registry_cache [label="skill pull"];
  cli -> context_mcp [label="context-mcp"];
  cli -> fun_mcp [label="fun-mcp"];

  tui -> engine [label="spawn engine task"];
  tui -> composer;
  tui -> markdown;
  tui -> status;
  tui -> theme;
  tui -> state;
  tui -> acp_permission [label="approval channel"];
  tui -> event_store [label="queued/obs"];

  agent -> engine [label="EnginePool"];
  cli -> daemon_proc [style=dashed, color="#d97706", label="spawn"];
  agent -> tcp [style=dashed, color="#d97706", label="listen/connect"];
  tcp -> agent [style=dashed, color="#d97706", label="JSON line"];

  engine -> acp [label="ensure_client/prompt"];
  engine -> context [label="compose capsule"];
  engine -> skills [label="load/match"];
  engine -> skill_runner [label="matched MCP skill"];
  engine -> event_store [label="events/timing/cache"];
  engine -> memory [label="recall/write"];
  engine -> session_ledger [label="session/turn/handoff"];
  engine -> runtime_event [label="record events"];
  engine -> config [label="backend config/env"];
  engine -> utils [label="summarize"];

  acp -> acp_wire;
  acp -> acp_session;
  acp -> acp_permission;
  acp -> runtime_event;
  acp -> mcp_router;
  acp -> acp_backend [style=dashed, color="#dc2626", label="stdio JSON-RPC"];
  acp_session -> mcp_sidecar [style=dashed, color="#dc2626", label="mcpServers spawn by backend"];
  acp_permission -> approval;
  acp_permission -> acp_backend [style=dashed, color="#16a34a", label="optionId: allow\n(iota tools)"];
  context -> acp_backend [style=dotted, color="#7c3aed", label="&lt;memory-tools&gt;\nin prompt"];
  mcp_router -> memory [label="iota_memory_search"];
  mcp_router -> skills [label="iota_skill_search"];

  context -> skills [label="skill index"];
  context -> memory [label="memory buckets"];
  context -> git [style=dashed, color="#dc2626", label="Command"];
  skill_runner -> mcp_client;
  mcp_client -> mcp_sidecar [style=dashed, color="#dc2626", label="stdio MCP"];
  mcp_sidecar -> context_mcp [style=dashed, color="#dc2626"];
  mcp_sidecar -> fun_mcp [style=dashed, color="#dc2626"];
  context_mcp -> memory;
  context_mcp -> skills;
  context_mcp -> session_ledger;
  fun_mcp -> tool_proc [style=dashed, color="#dc2626", label="run_command"];
  native_materializer -> memory;
  native_materializer -> skills;
  skill_registry_cache -> network [style=dashed, color="#2563eb", label="reqwest/local copy"];

  event_store -> runtime_event;
  event_store -> utils;
  memory -> utils;
  approval -> utils;
  session_ledger -> utils;
  config -> acp_session [label="AcpMcpServer"];
  config -> acp [label="AcpBackend"];
}
