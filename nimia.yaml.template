# iota-sympantos configuration template
# Copy this to ~/.i6/nimia.yaml and customize values.
# Backend config is read only from this file.
# The acp section starts the ACP adapter; update declares how automation should update it.

claude_code:
  enabled: true
  acp:
    command: npx
    args: ["-y", "@agentclientprotocol/claude-agent-acp@latest"]
  update:
    command: npx
    args: ["-y", "@agentclientprotocol/claude-agent-acp@latest", "--version"]
  model:
    provider: anthropic
    name: claude-sonnet-4
    base_url: https://api.anthropic.com
    api_key: <api-key>

codex:
  enabled: true
  acp:
    command: npx
    args: ["-y", "@zed-industries/codex-acp@latest"]
  update:
    command: npx
    args: ["-y", "@zed-industries/codex-acp@latest", "--version"]
  model:
    provider: ninerouter
    name: gh/gpt-5.5
    base_url: http://localhost:20128/v1
    api_key: <router-api-key>

gemini:
  enabled: true
  acp:
    command: npx
    args: ["-y", "@google/gemini-cli@latest", "--acp"]
  update:
    command: npx
    args: ["-y", "@google/gemini-cli@latest", "--version"]
  model:
    provider: google
    name: gemini-2.5-flash
    # api_key: <gemini-api-key>

opencode:
  enabled: true
  acp:
    command: npx
    args: ["-y", "opencode-ai@latest", "acp"]
  update:
    command: npx
    args: ["-y", "opencode-ai@latest", "--version"]
  model:
    provider: opencode
    name: MiniMax-M2.7

hermes:
  enabled: true
  acp:
    command: hermes
    args: ["acp"]
  update:
    command: hermes
    args: ["update"]
  model:
    provider: minimax-cn
    name: MiniMax-M2.7
    base_url: https://api.minimaxi.com/anthropic
    api_key: <api-key>


context_engine:
  enabled: true
  injection: auto
  memory_db: ~/.i6/context/memory.sqlite
  skill_roots:
    - ~/.i6/skills
    - ./.iota/skills
  native_overlays: false
  budgets:
    memory_chars: 2000
    skills_chars: 1200
    dialogue_chars: 1500
    workspace_chars: 800
  mcp:
    command: iota
    args: ["context-mcp"]
  fun:
    command: iota
    args: ["fun-mcp"]

context_engine_backend:
  gemini:
    mcp_session_new: true
  opencode:
    mcp_session_new: true
    always_send_empty_mcp_servers: true
  hermes:
    mcp_session_new: true
    mcp_env_shape: string_array
    override_home: false
  claude-code:
    mcp_session_new: try
  codex:
    mcp_session_new: try
