{
  "name": "cratesiota-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0205 node ../../scripts/dev-desktop.mjs",
    "dev:frontend": "NODE_OPTIONS=--disable-warning=DEP0205 vite",
    "dev:clean": "NODE_OPTIONS=--disable-warning=DEP0205 node ../../scripts/dev-desktop.mjs",
    "build": "NODE_OPTIONS=--disable-warning=DEP0205 tsc && NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "preview": "NODE_OPTIONS=--disable-warning=DEP0205 vite preview",
    "tauri": "NODE_OPTIONS=--disable-warning=DEP0205 tauri",
    "test": "node --test --import tsx \"src/**/*.test.ts\" \"src/**/*.test.tsx\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
